# 豆包（火山引擎 Ark / Doubao）可选配置
# 注意：不要把真实 key 提交到仓库。生产环境用部署平台的环境变量功能。

# OpenAI 兼容 ChatCompletions endpoint（以你控制台为准）
DOUBAO_ENDPOINT=https://ep-20260224210618-4g2fd.cn-beijing.volces.com/api/v3/chat/completions

# 你的接入点模型名（以控制台为准）
DOUBAO_MODEL=Doubao-1.5-pro-32k

# 你的 API KEY（不要写死在代码里）
DOUBAO_API_KEY=YOUR_API_KEY_HERE

